{
    "name": "itaotao/swiftphp-installer",
    "description": "SwiftPHP Framework Installer",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "symfony/console": "^6.0",
        "symfony/http-foundation": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "SwiftPHP\\Scaffold\\": "Scaffold/"
        }
    },
    "bin": ["swiftphp"],
    "minimum-stability": "dev",
    "prefer-stable": true
}